    {
      "headings": [
        {
          "tag": "h1",
          "text": "Automating Data & Reporting on Azure with 99.9% Data Accuracy"
        },
        {
          "tag": "h2",
          "text": "Our Azure experts implemented an end-to-end automated reporting platform that aggregates data from Azure SQL and Google Analytics, visualizing it with the help of Power BI."
        }
      ],
      "paragraphs": [],
      "listItems": [],
      "ctas": [
        {
          "text": "EXPLORE ENERGY DATA SOLUTIONS",
          "href": "#pgForm"
        }
      ],
      "images": [
        {
          "src": "https://azure.folio3.com/wp-content/uploads/2025/07/automatic-data-reporting.webp",
          "alt": null,

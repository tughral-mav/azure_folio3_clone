    {
      "items": [
        {
          "t": "h",
          "tag": "h2",
          "text": "Why Partner with Folio3 as your Microsoft Cloud Solution Provider"
        },
        {
          "t": "p",
          "text": "Your Success is our Priority"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "One-stop-shop"
        },
        {
          "t": "p",
          "text": "Your single point of contact for all cloud services and business applications, simplifying your tech management and ecosystem"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Flexible Payment Plans"
        },
        {
          "t": "p",
          "text": "Access cloud & business app licenses without upfront costs. Choose monthly or annual billing, with the option to adjust fees based on actual usage."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Better Pricing Guaranteed"
        },
        {
          "t": "p",
          "text": "Gain access to competitive pricing compared to traditional options without worrying about implementation cost and consumption lifecycles."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Your Trusted Advisor"
        },
        {
          "t": "p",
          "text": "Your trusted technology advisor to guide you in selecting the right services and applications to optimize your technology investments."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "24/7 Ongoing Support"
        },
        {
          "t": "p",
          "text": "From initial setup to ongoing maintenance and troubleshooting, get access to top-notch technical support and a range of services."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Microsoft Expertise"
        },
        {
          "t": "p",
          "text": "Improve your IT efficiency with a esteemed Tier-1 Microsoft Solution Designation Partner who is also a Global Cloud Solution Provider in more than 8 Regions Across the Globe."
        },
        {
          "t": "cta",
          "text": "Request a call",
          "href": "#pgForm"
        }
      ],

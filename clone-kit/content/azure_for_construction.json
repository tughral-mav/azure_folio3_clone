      "items": [
        {
          "t": "h",
          "tag": "h2",
          "text": "Azure Solutions For Construction Managers"
        },
        {
          "t": "p",
          "text": "Our Microsoft Azure-powered, construction industry solutions are built to empower construction managers to build smarter, not harder, by accessing real-time insights and predictive analytics, keeping projects on schedule and under budget."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Enhanced Collaboration"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Efficient Team Synergy"
        },
        {
          "t": "p",
          "text": "Achieve error-free workflows, foster real-time information sharing, and enable prompt decision-making across all construction stakeholders."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Key Azure Integrations"
        },
        {
          "t": "p",
          "text": "Leverage Azure Virtual Desktop to access powerful applications such as Azure Files for centralized document storage, Azure DevOps for agile project management, and integrated Microsoft Teams for instant communication."
        },
        {
          "t": "cta",
          "text": "Find Out More",
          "href": "#pgForm"
        },
        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2025/06/sec-4-2-elementor-io-optimized.webp",
          "w": 796,
          "h": 641,
          "alt": ""
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Smart Project Management"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Smart Project Foresight"
        },
        {
          "t": "p",
          "text": "Gain the power of predictive insights, optimize resource utilization, and establish data-driven control over all your project workflows."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Data-Driven Foundations"
        },
        {
          "t": "p",
          "text": "Implement Azure IoT to monitor equipment utilization and environmental conditions in real-time. Access Azure Data Lake to ingest large data sets, process insights with Azure Synapse Analytics, and oversee KPIs through Power BI dashboards."
        },
        {
          "t": "cta",
          "text": "Find Out More",
          "href": "#pgForm"
        },
        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2025/06/sec-4-1-elementor-io-optimized.webp",
          "w": 160,
          "h": 150,
          "alt": ""
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Scalable BIM & Design Ops"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Unlock BIM’s Potential"
        },
        {
          "t": "p",
          "text": "Gain the power of predictive insights, optimize resource utilization, and establish data-driven control over all your project workflows."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "High-Performance Cloud Design"
        },
        {
          "t": "p",
          "text": "Achieve high-performance computing capabilities with Azure Virtual Machines. Store massive data sets on Azure Storage (Blob Storage and Data Lake Storage)."
        },
        {
          "t": "cta",
          "text": "Find Out More",
          "href": "#pgForm"
        },
        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2025/06/BIM-elementor-io-optimized.webp",
          "w": 187,
          "h": 150,
          "alt": ""
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "AI & ML for Construction"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Innovating with AI and ML"
        },
        {
          "t": "p",
          "text": "Automate redundant tasks, predict equipment maintenance needs, and optimize construction projects through smart algorithms."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Intelligent Automation Tools"
        },
        {
          "t": "p",
          "text": "Take full control of Azure AI services for custom AI models and Azure Machine Learning for developing and deploying predictive models and analytics solutions."
        },
        {
          "t": "cta",
          "text": "Find Out More",
          "href": "#pgForm"
        },

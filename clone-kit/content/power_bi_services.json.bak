      "headings": [
        {
          "tag": "h2",
          "text": "BI Infrastructure Services We Deliver"
        },
        {
          "tag": "h3",
          "text": "Data Integration"
        },
        {
          "tag": "h3",
          "text": "Data Quality Management"
        },
        {
          "tag": "h3",
          "text": "Data Storage"
        },
        {
          "tag": "h3",
          "text": "Data Analytics"
        },
        {
          "tag": "h3",

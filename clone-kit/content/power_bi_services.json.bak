        {
          "tag": "h1",
          "text": "Power BI Business Intelligence Services & Solutions"
        },
        {
          "tag": "h2",
          "text": "At Folio3, we cut through the noise by building industry-wide business intelligence solutions powered by Power BI. Transform raw data into valuable insights consisting of immersive reports and interactive dashboards."
        }
      ],
      "paragraphs": [],
      "listItems": [],

          "text": "Go from raw data to AI-driven insights—faster and smarter."
        }
      ],
      "paragraphs": [],
      "listItems": [],
      "ctas": [
        {
          "text": "Bring Your AI Vision to Reality",
          "href": "#pgForm"
        }
      ],

    {
      "headings": [
        {
          "tag": "h2",
          "text": "Why Leverage Azure Services For Construction"
        },
        {
          "tag": "h3",
          "text": "Gain Unified Project Intelligence"
        },
        {
          "tag": "h3",
          "text": "BIM Collaboration and High-Performance Design"
        },

      "items": [
        {
          "t": "h",
          "tag": "h2",
          "text": "One Source of Truth, Powered by IntelliFabric"
        },
        {
          "t": "h",
          "tag": "h2",
          "text": "Folio3 deployed its IntelliFabric Solution — a purpose-built analytics offering designed for seamless integration with Microsoft Dynamics 365 Business Central, built on Azure and Microsoft Fabric. The solution established a secure, direct connection to the client's Business Central environment and transformed transactional data into interactive, pre-built dashboards. Manual reporting was eliminated. Finance, Sales, and Inventory came into a single, real-time view of the business. What IntelliFabric delivered:"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Secure integration with Dynamics 365 Business Central"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Automated data extraction and transformation"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Pre-built Finance, Sales, and Inventory dashboards"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Real-time KPI tracking against budget and history"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Unified, single view of business performance"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Interactive and visual analytics"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Scalable analytics foundation"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Elimination of manual reporting effort"
        },
        {
          "t": "cta",
          "text": "TRANSFORM YOUR GROWER DATA",
          "href": "#pgForm"
        }
      ],

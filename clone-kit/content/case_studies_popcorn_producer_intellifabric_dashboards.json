      "items": [
        {
          "t": "h",
          "tag": "h2",
          "text": "Key Features"
        },
        {
          "t": "p",
          "text": "The Business Central Dashboards Suite delivered three core capability sets, each addressing a specific area of operational oversight."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Financial Performance Monitoring"
        },
        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2026/01/expense-analysis-icon.svg",
          "w": 216,
          "h": 150,
          "alt": ""
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Income & Balance Sheet Overview"
        },
        {
          "t": "p",
          "text": "Provided immediate visibility into key financial statements."
        },
        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2026/01/income-balance-sheet-overview-icon.svg",
          "w": 216,
          "h": 150,
          "alt": ""
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Profitability Metrics"
        },
        {
          "t": "p",
          "text": "Tracked Gross Profit (USD) and Net Profit (USD) with Year-over-Year (YoY) comparisons for quick performance assessment"
        },
        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2026/01/profitability-metrics-icon.svg",
          "w": 216,
          "h": 150,
          "alt": ""
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Liquidity Ratios"
        },
        {
          "t": "p",
          "text": "Displayed vital metrics like the Current Ratio and Quick Ratio for instantaneous financial health checks."
        },
        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2026/01/liquidity-ratios-icon.svg",
          "w": 216,
          "h": 150,
          "alt": ""
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Expense Analysis"
        },
        {
          "t": "p",
          "text": "Broke down Total Expenses by category (Facility, Management, Banking, etc.) and provided Budget vs. Actual comparisons."
        },
        {
          "t": "cta",
          "text": "Achieve These With Copilot",
          "href": "#pgForm"
        },
        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2026/01/financial-performance-monitoring.webp",
          "w": 184,
          "h": 150,
          "alt": ""
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Sales and Customer Insights"
        },
        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2026/01/sales-performance-tracking-icon.svg",
          "w": 216,
          "h": 150,
          "alt": ""
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Sales Performance Tracking"
        },
        {
          "t": "p",
          "text": "Monitored metrics such as Sales (USD) FYOYTD and Adjusted Profit (%)."
        },
        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2026/01/budet-comparison-icon.svg",
          "w": 216,
          "h": 150,
          "alt": ""
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Budget Comparison"
        },
        {
          "t": "p",
          "text": "Visualized monthly and departmental Sales vs. Budget trends."
        },
        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2026/01/detailed-analysis-icon.svg",
          "w": 216,
          "h": 150,
          "alt": ""
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Detailed Analysis"
        },
        {
          "t": "p",
          "text": "Allowed deep dives into performance by specific Customer and Salesperson"
        },
        {
          "t": "cta",
          "text": "Achieve These With Copilot",
          "href": "#pgForm"
        },
        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2026/01/sales-customer-insights.webp",
          "w": 184,
          "h": 150,

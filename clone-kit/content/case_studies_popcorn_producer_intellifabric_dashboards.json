      "items": [
        {
          "t": "h",
          "tag": "h3",
          "text": "Indiana, United States"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Farming and Seed Production"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "11–50 employees"
        },
        {
          "t": "p",
          "text": "About The Client"
        },
        {
          "t": "h",
          "tag": "h2",
          "text": "Weaver Popcorn Hybrids"
        },
        {
          "t": "p",
          "text": "Our client is a leading producer of popcorn hybrids, operating at scale across global production and distribution. With deep expertise in seed development and a long-standing position in the popcorn industry, the company manages a complex operational footprint — from agronomy and production planning to inventory, sales, and global distribution. That complexity demanded a robust analytics layer capable of turning raw ERP data into actionable business intelligence. The leadership team needed a single, reliable source of truth — not another report waiting to be built."
        }
      ],

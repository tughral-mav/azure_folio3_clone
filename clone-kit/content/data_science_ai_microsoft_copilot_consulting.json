      "items": [
        {
          "t": "h",
          "tag": "h2",
          "text": "Microsoft Copilot In Action"
        },
        {
          "t": "p",
          "text": "Proper deployment of Microsoft Copilot boosts productivity across applications:"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Microsoft Word"
        },
        {
          "t": "p",
          "text": "Create executive summaries quickly, automate document generation, and receive intelligent text suggestions."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Microsoft Excel"
        },
        {
          "t": "p",
          "text": "Automate data analysis, explain formulas, format data, identify trends, and reconcile financial data in minutes."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Microsoft Teams"
        },
        {
          "t": "p",
          "text": "Get meeting summaries in real-time with intelligent suggestions and answers to specific questions during or after calls."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Microsoft Outlook"
        },
        {
          "t": "p",
          "text": "Prioritize emails and Teams messages, summarize crucial conversations, and automate reminders and follow-up actions."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Microsoft PowerPoint"
        },
        {
          "t": "p",
          "text": "Intelligently design and automate slide formatting with advanced data visualization tools to generate professionally sound presentations."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Dynamics 365 Copilot"
        },
        {
          "t": "p",
          "text": "Automate customer services, sales processes, and boost customer engagement and experience."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Power Platform Copilot"
        },
        {
          "t": "p",
          "text": "Automate workflows, reduce development time, and enhance apps with AI-assisted coding."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Microsoft Security Copilot"
        },
        {
          "t": "p",
          "text": "Detect vulnerabilities and instantly respond to threats with strengthened overall security measures."
        }
      ],

          "t": "h",
          "tag": "h2",
          "text": "Key Features"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "24/7 AI-Powered Self-Service"
        },
        {
          "t": "p",
          "text": "Employees get instant, natural-language answers to policy questions at any time, on any device."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Strict Security Guardrails"
        },
        {
          "t": "p",
          "text": "Custom-configured filters to reject off-topic, political, or unrelated queries, ensuring the agent remains professional and compliant."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "NLP Conversational Interface"
        },
        {
          "t": "p",
          "text": "A user-friendly chat experience that understands intent, reducing the need for employees to search through long PDF manuals."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Deep Document Grounding"
        },
        {
          "t": "p",
          "text": "Unlike generic AI, this agent only provides answers cited from company’s specific, approved policy texts."
        }
      ],

      "headings": [
        {
          "tag": "h2",
          "text": "Microsoft Fabric - Features and Benefits"
        },
        {
          "tag": "h3",
          "text": "Unified User Experience"
        },
        {
          "tag": "h3",
          "text": "Next-level Collaboration"
        },
        {
          "tag": "h3",
          "text": "Scalability for Constant Growth"
        },
        {
          "tag": "h3",

    {
      "items": [
        {
          "t": "h",
          "tag": "h2",
          "text": "End‑to‑End Agentic Workflow"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Self‑Help HR Policy Agent"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Employees interact with the Copilot Studio agent to:"
        },
        {
          "t": "li",
          "text": "Ask questions about HR policies"
        },
        {
          "t": "li",
          "text": "Receive instant, grounded responses sourced from approved SharePoint documents"
        },
        {
          "t": "h",
          "tag": "h4",
          "text": "Value Delivered"
        },
        {
          "t": "p",
          "text": "Reduced dependency on HR teams and faster resolution of routine policy queries."
        },
        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2026/01/self-help-hr-poliy-agent.webp",
          "w": 182,
          "h": 150,
          "alt": ""
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Guided Feedback Collection"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "When employees identify issues such as:"
        },
        {
          "t": "li",
          "text": "Unclear or vague policies"
        },
        {
          "t": "li",
          "text": "Missing clauses"
        },
        {
          "t": "li",
          "text": "Insufficient explanation"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "The agent:"
        },
        {
          "t": "li",
          "text": "Asks guided follow‑up questions"
        },
        {
          "t": "li",
          "text": "Captures structured feedback within the same conversation"
        },
        {
          "t": "h",
          "tag": "h4",
          "text": "Value Delivered"
        },
        {
          "t": "p",
          "text": "High‑quality, actionable feedback instead of informal emails or chats."
        },
        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2026/01/guided-feedback-collection.webp",
          "w": 182,
          "h": 150,
          "alt": ""
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Automated Feedback Capture"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "The agent automatically:"
        },
        {
          "t": "li",
          "text": "Summarizes employee feedback"
        },
        {
          "t": "li",
          "text": "Stores it in Excel on SharePoint"
        },
        {
          "t": "li",
          "text": "Tags the relevant policy and clause"
        },
        {
          "t": "li",
          "text": "Maintains a traceable feedback log"
        },
        {
          "t": "h",
          "tag": "h4",
          "text": "Value Delivered"
        },
        {
          "t": "p",
          "text": "Fully automated feedback capture with zero manual effort."
        },
        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2026/01/automated-feedback-capture.webp",
          "w": 182,
          "h": 150,
          "alt": ""
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Feedback Analysis & Insights"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "HR analysts review:"
        },
        {
          "t": "li",
          "text": "Excel‑based feedback dashboards"
        },
        {
          "t": "li",
          "text": "Trends across policies and clauses"
        },
        {
          "t": "li",
          "text": "Frequency and severity of reported issues"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "This enables faster identification of:"
        },
        {
          "t": "li",
          "text": "Policies requiring updates"
        },
        {
          "t": "li",
          "text": "Sections causing repeated confusion"
        },
        {

        {
          "t": "img",
          "src": "https://azure.folio3.com/wp-content/uploads/2023/06/about_us-mock.webp",
          "w": 705,
          "h": 529,
          "alt": "discover the essence of who we are?"
        },
        {
          "t": "p",
          "text": "Microsoft Azure is a dedicated department of Folio3 that provides a wide range of services related to Azure, including managed services, implementation, data analytics, and much more. Folio3 is a partner of Microsoft Technology and has extensive experience working with Microsoft Azure in the regions of the United States, United Kingdom, the Middle East, and Australia for more than 8 years."
        }

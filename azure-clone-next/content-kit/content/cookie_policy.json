        {
          "t": "h",
          "tag": "h3",
          "text": "What are Cookies?"
        },
        {
          "t": "p",
          "text": "Cookies are small text files saved on devices from websites visited. They allow the website to record personal details and preferences (such as login, font size, and display preferences) to avoid the hassle of reentering this information on every visit to the particular webpage."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Third-party cookies"
        },
        {
          "t": "li",
          "text": "To track your browser across multiple websites"
        },
        {
          "t": "li",
          "text": "To build a profile of your web surfing"
        },
        {
          "t": "li",
          "text": "To target advertisements that may be of particular interest to you"
        },
        {
          "t": "li",
          "text": "To analyze the use of the website (analytics tools)"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "How Do We Use Them?"
        },
        {
          "t": "li",
          "text": "Improve the website’s usability"
        },
        {
          "t": "li",
          "text": "Improve the website user experience"
        },
        {
          "t": "li",
          "text": "Analyze the use of the website"
        },
        {
          "t": "li",
          "text": "Personalize the website for visitors, including targeted marketing strategies"
        },
        {
          "t": "li",
          "text": "Analyzing the use of the website"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Third Party Cookies"
        },
        {
          "t": "li",
          "text": "Tracking a browser across multiple websites"
        },
        {
          "t": "li",
          "text": "Building a profile of web surfing activities"
        },
        {
          "t": "li",
          "text": "Targeting advertisements according to user interests"
        },
        {
          "t": "li",
          "text": "Analyzing the use of the website"
        },

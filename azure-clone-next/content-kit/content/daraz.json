          "t": "h",
          "tag": "h2",
          "text": "The Problem"
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "The web portals and middleware apps should be hosted in Azure as app services."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "They should be connecting with Dynamics AX 2012 hosted on-premise."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Azure single sign-on for mobile apps and web portals."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Infrastructure security & Application monitoring."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Mobile apps build distribution."
        },
        {
          "t": "h",
          "tag": "h3",
          "text": "Disaster recovery."
        }
      ],
